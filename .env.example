# Copy to .env and fill in. The app runs fully on defaults for local dev.
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000

# Optional: point at a real Postgres (Neon/Supabase). Unset → embedded PGlite.
# DATABASE_URL=postgres://user:pass@host/db

# ── Midtrans (payment gateway) ──
# Empty keys → simulation mode (in-app sandbox dialog, no real charges), so the
# checkout flow works out of the box. To use Midtrans Sandbox for real:
#   1. Sign up at https://dashboard.sandbox.midtrans.com
#   2. Settings → Access Keys → copy Server Key + Client Key below
#   3. Settings → Configuration → set Payment Notification URL to
#      https://<your-public-host>/api/midtrans/notification  (use ngrok in dev)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
