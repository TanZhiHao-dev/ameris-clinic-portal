# Copy to .env and fill in. The app runs fully on defaults for local dev.
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000

# ── Google Analytics 4 (booking-funnel tracking) ──
# Empty → no analytics script loads at all (dev & preview stay clean).
#   1. analytics.google.com → Admin → Create property → add a Web data stream
#      for https://ameris-clinic.com → copy the "G-XXXXXXXXXX" Measurement ID
#   2. Set it here for local testing AND in Coolify env for production.
# NOTE: VITE_ vars are baked in at build time — after setting it in Coolify,
# trigger a redeploy/rebuild or it won't take effect.
VITE_GA_MEASUREMENT_ID=

# Database. Unset → embedded PGlite (file-backed at ./.data/ameris, dev only).
# Set DATABASE_URL → real Postgres (permanent). Migrations apply on boot.
#   • Coolify-managed Postgres (same project): use the INTERNAL URL Coolify shows,
#     e.g. postgres://postgres:PASSWORD@<service-name>:5432/postgres  (no SSL)
#   • Managed cloud (Neon/Supabase): append ?sslmode=require
# DATABASE_URL=postgres://user:pass@host:5432/db

# Seed guard. /api/seed WIPES + reseeds every table, so in production it is
# refused unless SEED_TOKEN is set; then call /api/seed?token=<SEED_TOKEN> once.
# Leave unset in local dev (seeding stays open there).
# SEED_TOKEN=

# ── Midtrans (payment gateway) ──
# Empty keys → simulation mode (in-app sandbox dialog, no real charges), so the
# checkout flow works out of the box. To use Midtrans Sandbox for real:
#   1. Sign up at https://dashboard.sandbox.midtrans.com
#   2. Settings → Access Keys → copy Server Key + Client Key below
#   3. Settings → Configuration → set Payment Notification URL to
#      https://<your-public-host>/api/midtrans/notification  (use ngrok in dev)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ── Resend (transactional email — password reset link) ──
# Empty key → emails are logged to the server console instead of sent (the reset
# flow still works for dev). To send real email:
#   1. Sign up at https://resend.com and create an API key
#   2. Verify a sending domain (Domains → Add), then set RESEND_FROM to an address
#      on it, e.g. "Ameris Aesthetic Clinic <noreply@ameris-clinic.com>"
#   (without a verified domain, Resend's onboarding@resend.dev only delivers to
#    your own Resend account email — fine for a quick test)
RESEND_API_KEY=
RESEND_FROM=Ameris Aesthetic Clinic <onboarding@resend.dev>

# ── Google sign-in (OAuth) ──
# Both empty → the "Lanjutkan dengan Google" button is hidden and email+password
# still works. To enable Google login/register:
#   1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client
#      ID (type: Web application)
#   2. Authorized redirect URIs — add BOTH:
#        http://localhost:3000/api/auth/callback/google     (dev)
#        https://ameris-clinic.com/api/auth/callback/google  (prod — match BETTER_AUTH_URL)
#   3. Copy the Client ID + Client secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
